generator client {
  provider = "prisma-client"
  output   = "../src/lib/prisma/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/****************************************************************************
 * Tabela de histórico de tickets nao usada, mas mantida para referencia futura
 ****************************************************************************/
model Ticket {
  id String @id @default(uuid())
  // id    Int     @id @default(autoincrement())
  titulo String
  assunto String
  urgencia String
  status String @default("aberto")
  criador String
  analista String? // O "?" torna o campo anulável (NULL) no banco de dados
  // responsavel String? // O "?" torna o campo anulável (NULL) no banco de dados
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  //histories  TicketHistory[]

  @@map("tickets")
}


