// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/lib/prisma/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// tabela tickets
model Ticket {
  id String @id @default(uuid())
  // id    Int     @id @default(autoincrement())
  titulo String
  assunto String
  urgencia String
  status String @default("aberto")
  criador String
  analista String? // O "?" torna o campo anulável (NULL) no banco de dados
  // responsavel String? // O "?" torna o campo anulável (NULL) no banco de dados
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  histories  TicketHistory[]

  @@map("tickets")
}


model TicketHistory {
  id          String   @id @default(uuid())
  // Chave estrangeira
  ticketId    String
  // Relação
  ticket       Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  mensagem     String
  analista     String
  // status       String?
  // Comentário, alteração de status, anexo, etc.
  tipo         String   @default("comentario")

  statusAntes  String?
  statusDepois String?
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("ticket_history")
}


model User {
  id String @id @default(uuid())
  // id    Int     @id @default(autoincrement())
  nome String
  email String @unique
  senha String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}